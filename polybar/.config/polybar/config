
[colors]
;background = ${xrdb:color0:#222}
background = #222
background-alt = #444
;foreground = ${xrdb:color7:#222}
foreground = #ffffff
foreground-alt = #ffffff
primary = #ffb52a
secondary = #e60053
alert = #bd2c40

[bar/i3]
width = 100%
height = 23
fixed-center = true
offset-x = 0
offset-y = 0 

background = #27282a
foreground = ${colors.foreground}

line-size = 3
line-color = #f00

border-size = 5 
border-color = #00000000
border-bottom-size = 2 
border-bottom-color = #00000000

padding-left = 0 
padding-right = 1

module-margin-left = 1
module-margin-right = 2

font-0 = fixed:pixelsize=10;1
font-1 = unifont:fontformat=truetype:size=8:antialias=false;0
font-2 = siji:pixelsize=10;
font-3 = FontAwesome:pixelsize=10;1
font-4 = Inconsolata Patched:pixelsize=20;0
font-5 = fontello:pixelsize=15;1

modules-left = xworkspaces 
modules-center = date 
modules-right = xbacklight volume battery 

tray-position = right
tray-padding = 2

[module/xbacklight]
type = internal/xbacklight

; Available tokens:
format = <ramp> <bar>
;   %percentage% (default)
label = %percentage%%

; Only applies if <ramp> is used
ramp-0 = ЁЯМХ
ramp-1 = ЁЯМФ
ramp-2 = ЁЯМУ
ramp-3 = ЁЯМТ
ramp-4 = ЁЯМС

bar-width = 10
bar-indicator = |
bar-indicator-font = 2
bar-fill = тФА
bar-fill-font = 2
bar-fill-foreground = #9f78e1
;bar-fill-foreground = #ffffff
bar-indicator-foreground = #fff
bar-empty-font = 2
bar-empty-foreground = ${colors.foreground-alt}
bar-empty = тФА

[module/backlight-acpi]
inherit = module/xbacklight
type = internal/backlight
card = intel_backlight

[module/date]
type = internal/date
interval = 5
date = %a %d,%b,%Y
date-alt = %Y-%m-%d

time = %H:%M
time-alt = %H:%M:%S

format = <label>
label = %date% - %time%

[module/volume]
type = internal/volume

format-volume =  <label-volume> <bar-volume>
label-volume =яАи
label-volume-foreground = #ffffff
format-muted-foreground = ${colors.foreground-alt}
format-foreground = ${colors.foreground-alt}
label-muted =  sound muted

bar-volume-width = 10
bar-volume-foreground-0 = #55aa55
bar-volume-foreground-1 = #55aa55
bar-volume-foreground-2 = #55aa55
bar-volume-foreground-3 = #55aa55
bar-volume-foreground-4 = #55aa55
bar-volume-foreground-5 = #f5a70a
bar-volume-foreground-6 = #ff5555
bar-volume-gradient = false
bar-volume-indicator = |
bar-volume-indicator-font = 2
bar-volume-indicator-foreground = #ffffff
bar-volume-fill = тФА
bar-volume-fill-font = 2
bar-volume-empty = тФА
bar-volume-empty-font = 2
bar-volume-empty-foreground = ${colors.foreground-alt}

[module/battery]
type = internal/battery
battery = BAT0
adapter = AC
full-at = 99 
time-format = %H:%M
label-full=яЙА %percentage%%
format-charging =  <animation-charging> <label-charging>

format-discharging =  <ramp-capacity> <label-discharging>

format-full-prefix-foreground = #ffffff 
label-discharging-foreground = #ffffff
label-charging-foreground = #ffffff
label-discharging = %percentage%% 
label-charging = %percentage%% 
; Only applies if <ramp-capacity> is used
ramp-capacity-0 = яЙД
ramp-capacity-1 = яЙГ
ramp-capacity-2 = яЙВ
ramp-capacity-3 = яЙБ
ramp-capacity-4 = яЙА
ramp-capacity-foreground= #ffffff
; Only applies if <animation-charging> is used

animation-charging-0 = яЙД
animation-charging-1 = яЙГ
animation-charging-2 = яЙВ
animation-charging-3 = яЙБ
animation-charging-4 = яЙА
animation-charging-foreground = ${colors.foreground}
animation-charging-framerate = 750

[module/wireless-network]
type = internal/network
interface = wlp1s0
interval = 3.0
format-connected = <label-connected>
label-connected =  яАТ  %essid%
label-connected-foreground = #ffffff
label-disconnected = Disconntected
label-disconnected-foreground  = #ffffff

[module/xworkspaces]
icon-0 = 1;яДа 
icon-1 = 2;яДа 
icon-2 = 3;яЙй 
icon-default =яДЙ 
type = internal/xworkspaces
label-active =%icon%
label-active-foreground = #ffffff
#label-active-background = #3f3f3f
label-active-padding = 2 
label-active-underline = #bb4455
label-empty = %icon%
label-empty-foreground = #55
label-empty-padding = 2  

[global/wm]
margin-top = 5
margin-bottom = 5

; vim:ft=dosini
